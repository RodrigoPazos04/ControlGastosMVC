@model List<ControlGastos.Models.Gasto>

<h1 class="text-center mb-4">Control de Gastos</h1>

<form method="get" class="mb-3">
    <select name="categoria" class="form-select w-25 d-inline">
        <option value="">Todas</option>
        <option value="Comida">Comida</option>
        <option value="Transporte">Transporte</option>
        <option value="Otros">Otros</option>
    </select>

    <button type="submit" class="btn btn-secondary">Filtrar</button>
</form>

<form method="post" asp-action="AgregarGasto" class="mb-4">
    <div class="row">

        <div class="col">
            <input type="text" name="Descripcion" class="form-control" placeholder="Descripción" />
        </div>

        <div class="col">
            <input type="number" step="0.01" name="Monto" class="form-control" placeholder="Monto" />
        </div>

        <div class="col">
            <input type="text" name="Categoria" class="form-control" placeholder="Categoría" />
        </div>

        <div class="col">
            <button type="submit" class="btn btn-primary">Agregar</button>
        </div>

    </div>
</form>

<h4 class="text-end mb-3">
    Total gastado: <span class="text-success">$@ViewBag.Total</span>
</h4>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Descripción</th>
            <th>Monto</th>
            <th>Categoría</th>
            <th>Fecha</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var gasto in Model)
        {
            <tr>
                <td>@gasto.Descripcion</td>
                <td>@gasto.Monto</td>
                <td>@gasto.Categoria</td>
                <td>@gasto.Fecha.ToShortDateString()</td>

                <td>
                    <a asp-action="EditarGasto" asp-route-id="@gasto.Id" class="btn btn-sm btn-warning me-2">
                        Editar
                    </a>

                    <form method="post" asp-action="EliminarGasto" style="display:inline;">
                        <input type="hidden" name="id" value="@gasto.Id" />
                        <button type="submit" class="btn btn-sm btn-danger">
                            Eliminar
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>